# Copy to ".env" in the repo root. Never commit ".env" (see .gitignore).
# Other app variables: README "Configuration (environment)".

# --- Primary LLM (OpenAI-compatible …/v1/chat/completions) ---
SENSOR_APP_LLM_ENABLED=false
SENSOR_APP_LLM_BASE_URL=https://api.openai.com/v1
SENSOR_APP_LLM_API_KEY=
SENSOR_APP_LLM_MODEL=gpt-4o-mini

# --- Fallback LLM (after primary transient failures; default enabled) ---
# Set BASE_URL + MODEL (and API_KEY if not the same vendor as primary). Example Groq:
# SENSOR_APP_LLM_FALLBACK_BASE_URL=https://api.groq.com/openai/v1
# SENSOR_APP_LLM_FALLBACK_API_KEY=gsk_...
# SENSOR_APP_LLM_FALLBACK_MODEL=llama-3.1-8b-instant
SENSOR_APP_LLM_FALLBACK_ENABLED=true
SENSOR_APP_LLM_FALLBACK_BASE_URL=
SENSOR_APP_LLM_FALLBACK_API_KEY=
SENSOR_APP_LLM_FALLBACK_MODEL=
