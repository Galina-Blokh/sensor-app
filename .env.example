# Copy to ".env" and fill in secrets. Never commit ".env".
#
# sensor_app loads LLM settings as SENSOR_APP_* (see README). If you only set
# OPENAI_API_KEY in your shell, mirror it: SENSOR_APP_LLM_API_KEY must be set for /llm/* routes.

SENSOR_APP_LLM_ENABLED=true
SENSOR_APP_LLM_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
